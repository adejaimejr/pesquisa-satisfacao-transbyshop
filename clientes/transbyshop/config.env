# ── TransbyShop — cliente #1 (PRODUÇÃO) ──
# Valores EXATOS do HTML original. NÃO alterar sem rodar o gate de parity.
# Apps Script URL vem por env var no deploy: APPS_SCRIPT_URL_TRANSBYSHOP

# Domínio: vazio = servido pelo `default` do nginx map (catch-all). Preencher se quiser rota explícita.
DOMAIN=""

COMPANY_NAME="TransbyShop"
LOGO_FILE="logo-1.svg"
HEADER_LOGO_FILTER="brightness(0) invert(1)"

PRIMARY="#570d32"
PRIMARY_DARK="#3d0922"
PRIMARY_GLOW="#7a1540"
ACCENT="#e53842"
ACCENT2="#e15b2d"
BLUSH_LIGHT="#fdf5f7"
BLUSH="#f9eaed"
BLUSH_MID="#f0cdd4"
TEXT_MAIN="#1a0810"
TEXT_MUTED="#7a5560"
BORDER="#edd5db"
BG="#FFFFFF"
REQ_BG="#f5e8eb"
SHADOW_RGB="158,35,74"
HOVER_RGB="254,110,137"
ARROW="9E234A"

HEADER_BG="linear-gradient(135deg, var(--primary-dark) 0%, var(--primary) 55%, #7a1540 100%)"
HEADER_TEXT="#fff"
HEADER_EYEBROW="rgba(255,255,255,0.60)"
HEADER_SUB="rgba(255,255,255,0.68)"
HEADER_SUB_STRONG="rgba(255,255,255,0.95)"
ON_PRIMARY="#fff"
CTA_BG="linear-gradient(135deg, var(--primary-dark) 0%, var(--primary) 50%, #7a1540 100%)"
CTA_TEXT="#fff"
HERO_BG="linear-gradient(160deg, var(--primary-dark) 0%, var(--primary) 45%, #7a1540 100%)"
